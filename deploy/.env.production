SMTP_FROM_NAME=SMART MAINTENANCE

# Firebase Configuration
FIREBASE_PROJECT_ID=smart-maintenance-fbd60
# Le fichier firebase-service-account.json doit être présent

# FineoPay Configuration
FINEOPAY_ENVIRONMENT=production
FINEOPAY_API_KEY=VOTRE_CLE_API_FINEOPAY
