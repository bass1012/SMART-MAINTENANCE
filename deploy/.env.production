# ================================================================
# Configuration Production - MCT Maintenance API
# Copier ce fichier en .env sur le serveur et modifier les valeurs
# ================================================================

# Server Configuration
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://dashboard.sandbox.mct.ci

# Database Configuration (PostgreSQL Local)
DATABASE_URL=postgresql://smartmaintenance:Keep0ut2026!@localhost:5432/smartmaintenance_db

# JWT Configuration (CHANGER CES CLÉS EN PRODUCTION!)
JWT_SECRET=GENERER_UNE_CLE_SECRETE_LONGUE_ET_ALEATOIRE_ICI
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=GENERER_UNE_AUTRE_CLE_SECRETE_DIFFERENTE
JWT_REFRESH_EXPIRE=30d

# Email Configuration (SMTP)
EMAIL_ENABLED=true
SMTP_HOST=mail.mct.ci
