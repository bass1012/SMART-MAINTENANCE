+  // Customer Reschedule
+  Future<Map<String, dynamic>> rescheduleIntervention(int interventionId, DateTime newDate) async {
+    try {
+      final response = await _apiService.post(
+        '/customer/interventions/$interventionId/reschedule',
+        data: {
+          'scheduled_date': newDate.toIso8601String(),
+        },
+      );
+      return response;
+    } catch (e) {
+      print('Error rescheduling intervention: $e');
+      return {
+        'success': false,
+        'message': e.toString(),
+      };
+    }
+  }
