+  Future<Map<String, dynamic>> reportClientUnreachable(int interventionId, {String? notes}) async {
+    try {
+      final Map<String, dynamic> data = {};
+      if (notes != null && notes.isNotEmpty) {
+        data['notes'] = notes;
+      }
+      
+      final response = await _apiService.post(
+        '/technician/interventions/$interventionId/report-unreachable',
+        data: data,
+      );
+      return response;
+    } catch (e) {
+      print('Error reporting client unreachable: $e');
+      return {
+        'success': false,
+        'message': e.toString(),
+      };
+    }
+  }
